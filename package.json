{
  "name": "database",
  "version": "1.0.0",
  "description": "Milkshake Shop Database with Drizzle ORM",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node src/db/seed.js",
    "db:reset": "rm -f database.db database.db-shm database.db-wal && npm run db:migrate && npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ejs": "^6.0.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
